{
  "collectionName": "themes",
  "info": {
    "singularName": "theme",
    "pluralName": "themes",
    "displayName": "Theme"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "description": { "type": "richtext" },
    "editorialPerspective": { "type": "richtext" },
    "parentTheme": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::theme.theme"
    },
    "subthemes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::theme.theme",
      "mappedBy": "parentTheme"
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "concepts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::concept.concept"
    }
  }
}
